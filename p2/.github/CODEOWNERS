# Choice Properties — CODEOWNERS
#
# Files listed here require a review from the project owner
# before any pull request can be merged on GitHub.
# This protects critical build and security files from
# accidental or automated modification.
#
# Syntax: <file-pattern> <github-username-or-team>
# Replace @your-github-username with the actual owner username.

# Build script — generates config.js at Cloudflare Pages deploy time
p2/generate-config.js @your-github-username

# Cloudflare Pages security headers (CSP, HSTS, X-Frame-Options, etc.)
p2/_headers @your-github-username

# Complete database schema — run once in Supabase SQL Editor only
p2/SETUP.sql @your-github-username

# Core Supabase API client — all frontend API calls go through this
p2/js/cp-api.js @your-github-username

# Rental application logic
p2/js/apply.js @your-github-username
p2/js/apply-files.js @your-github-username
p2/js/apply-property.js @your-github-username
p2/js/apply-submit.js @your-github-username
p2/js/apply-validation.js @your-github-username
p2/js/apply-translations.js @your-github-username

# This file itself — prevents bypassing ownership rules
.github/CODEOWNERS @your-github-username

# Agent instruction files — rule changes require owner approval
p2/.agents/instructions.md @your-github-username
