# ============================================================
# CHOICE PROPERTIES — CRITICAL GITIGNORE
# This protects the project from:
#   ❌ Leaking secrets to GitHub
#   ❌ Committing auto-generated files
#   ❌ Polluting repo with environment-specific files
#   ❌ Breaking deployment pipeline
# ============================================================

# CRITICAL: config.js is generated at Cloudflare/Replit build time ONLY
# ⚠️  Never commit this file — it leaks credentials and breaks deployment
config.js
config.*.js

# CRITICAL: Secrets belong in Supabase and Cloudflare, NOT in this repository
# ⚠️  DO NOT commit .env files (they contain API keys, private keys, etc.)
.env
.env.*
*.env
.env.local
.env.*.local

# CRITICAL: Dependencies — this project has ZERO runtime npm packages
# ⚠️  If npm install was run, node_modules/ should NEVER be committed
node_modules/
package-lock.json.bak

# Replit-specific auto-generated files
# ⚠️  Never commit Replit environment-specific data
.replit
.replit-cache/
.replit-backup/
.upm/
replit_zip_error_log.txt

# Local development files (Replit environment)
# ⚠️  These are machine-specific and auto-generated
.cache/
.local/
.config/
.npm/
.nvm/

# Database files (NOT APPLICABLE — DB is Supabase, not local)
# Just in case: prevent commits of local SQL/database files
*.db
*.sqlite
*.sqlite3
*.sql.bak
migrations/*.sql.bak

# OS / editor noise
.DS_Store
Thumbs.db
.swp
.swo
*~
*.tmp
.idea/
.vscode/settings.json
.VS/
.visualstudiocode
launch.json

# Uploaded assets (user-uploaded files from testing)
attached_assets/
uploads/
downloads/
temp/
tmp/

# Build artifacts (if anyone tries to build locally)
dist/
build/
out/

# Log files (development/testing)
*.log
logs/
.log

# IDE temporary files
.project
.pydevproject
.c9/

# ============================================================
# WHY THESE RULES MATTER:
#
# config.js: Generated at deploy time with secrets injected.
#           Committing it breaks everything.
#
# .env: Contains API keys, private keys. NEVER goes to GitHub.
#       Supabase secrets and Cloudflare environment vars instead.
#
# node_modules/: Auto-installed from package.json.
#               Never commit generated files.
#
# .replit*: Replit environment-specific. Doesn't belong in git.
#
# Result: This project can be safely imported anywhere! 🏰
# ============================================================
